## Plugin Definition Integration

Most APIs can be used directly in plugin definitions:

```typescript
import { definePlugin } from "@utils/types";
import { definePluginSettings } from "@api/Settings";

const settings = definePluginSettings({
    enabled: {
        type: OptionType.BOOLEAN,
        description: "Enable feature",
        default: true
    }
});

export default definePlugin({
    name: "MyPlugin",
    description: "My plugin",
    authors: [{ name: "Me", id: 123n }],
    settings,
    
    // Use plugin definition properties
    chatBarButton: {
        render: (props) => <MyButton />,
        icon: MyIcon
    },
    
    messagePopoverButton: {
        render: (message) => ({ label: "Action", icon: MyIcon, onClick: () => {} }),
        icon: MyIcon
    },
    
    start() {
        // Additional API registrations
        MessageEvents.addMessageClickListener(this.handleClick);
    },
    
    stop() {
        MessageEvents.removeMessageClickListener(this.handleClick);
    }
});
```

