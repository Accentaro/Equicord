## Examples

### Minimal Plugin

```typescript
import definePlugin from "@utils/types";
import { EquicordDevs } from "@utils/constants";

export default definePlugin({
    name: "MinimalPlugin",
    description: "A minimal plugin example",
    authors: [EquicordDevs.YourName],
});
```

### Plugin with Settings and Patches

```typescript
import { definePluginSettings } from "@api/Settings";
import definePlugin, { OptionType } from "@utils/types";
import { EquicordDevs } from "@utils/constants";

const settings = definePluginSettings({
    enabled: {
        type: OptionType.BOOLEAN,
        description: "Enable feature",
        default: true,
    }
});

export default definePlugin({
    name: "ExamplePlugin",
    description: "Example plugin with settings",
    authors: [EquicordDevs.YourName],
    settings,
    patches: [
        {
            find: "unique string",
            replacement: {
                match: /pattern/,
                replace: "replacement"
            },
            predicate: () => settings.store.enabled
        }
    ]
});
```

**Remember:** When in doubt, look at existing plugins in `src/equicordplugins/` for reference. Follow established patterns and maintain consistency with the codebase.
