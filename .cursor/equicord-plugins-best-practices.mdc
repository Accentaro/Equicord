## State Management

### useState Patterns

**Initialize state from cache/defaults:**

```typescript
// ✅ GOOD - Initialize from cache
const cache = React.useMemo(() => getOrCreateCache(channelId), [channelId]);
const [items, setItems] = React.useState<GalleryItem[]>(() => cache.items);
const [hasMore, setHasMore] = React.useState<boolean>(() => cache.hasMore);

// ✅ GOOD - Lazy initial state
const [visibleRange, setVisibleRange] = useState(() => ({ start: 0, end: 50 }));

// ✅ GOOD - Update initial state when dependencies change
useEffect(() => {
    if (visibleRange.end === 50 && filteredItems.length > 0) {
        setVisibleRange({ start: 0, end: Math.min(initialEnd, filteredItems.length) });
    }
}, [filteredItems.length, initialEnd]);
```

### useStateFromStores

**ALWAYS include dependency array when mapper depends on reactive values:**

```typescript
import { useStateFromStores } from "@webpack/common";

// ✅ GOOD - With dependencies
const channelId = useStateFromStores([SelectedChannelStore], () => SelectedChannelStore.getChannelId());
const channel = useStateFromStores(
    [ChannelStore, SelectedChannelStore],
    () => channelId ? ChannelStore.getChannel(channelId) : null,
    [channelId] // ✅ Dependencies array required!
);

// ✅ GOOD - Settings hook
const { questButtonDisplay, unclaimedUnignoredQuests } = settings.use([
    "questButtonDisplay",
    "unclaimedUnignoredQuests"
]);
```

### Global State Management

**Pattern for shared state across components:**

```typescript
// ✅ GOOD - Global state with listeners
let globalState: GalleryState = { mode: "closed", channelId: null, selectedStableId: null };
const stateListeners = new Set<() => void>();

function setState(updates: Partial<GalleryState>): void {
    globalState = { ...globalState, ...updates };
    stateListeners.forEach(listener => listener());
}

// In component
const [localState, setLocalState] = React.useState<GalleryState>(() => globalState);

React.useEffect(() => {
    const listener = () => setLocalState({ ...globalState });
    stateListeners.add(listener);
    return () => { stateListeners.delete(listener); };
}, []);
```

