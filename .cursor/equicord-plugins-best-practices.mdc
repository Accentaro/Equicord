## Performance Optimizations

### React.memo for Components

**Use React.memo to prevent unnecessary re-renders:**

```typescript
// ✅ GOOD - Memoized component with custom comparison
function ThumbnailItemComponent({ item, thumbSize, showCaptions, failedVideos, onSelect, onMarkFailed, setFailedVideos }: Props) {
    // Component implementation
}

// Memoize if available, fallback if not
const ThumbnailItem = React.memo ? React.memo(ThumbnailItemComponent, (prev, next) => {
    // Custom comparison to prevent re-renders when props haven't changed
    return (
        prev.item.stableId === next.item.stableId &&
        prev.thumbSize === next.thumbSize &&
        prev.showCaptions === next.showCaptions &&
        prev.failedVideos.has(prev.item.stableId) === next.failedVideos.has(next.item.stableId)
    );
}) : ThumbnailItemComponent;
```

### useMemo for Expensive Calculations

**Memoize expensive computations:**

```typescript
// ✅ GOOD - Memoize filtered/transformed data
const filteredItems = useMemo(() => {
    return filterItems(items, filter);
}, [items, filter]);

// ✅ GOOD - Memoize layout calculations
const gridLayout = useMemo(() => {
    const usableWidth = Math.max(1, viewport.width - PADDING * 2);
    const columns = Math.max(1, Math.floor((usableWidth + GAP) / (MIN_THUMB + GAP)));
    const cell = Math.max(MIN_THUMB, Math.min(MAX_THUMB, Math.floor((usableWidth - (columns - 1) * GAP) / columns)));
    return { columns, cell, thumbSize: Math.max(128, Math.min(512, cell * 2)) };
}, [viewport.width]);

// ✅ GOOD - Memoize cache creation
const cache = React.useMemo(() => getOrCreateCache(channelId), [channelId]);
```

### useCallback for Event Handlers

**Memoize callbacks to prevent child re-renders:**

```typescript
// ✅ GOOD - Memoized callbacks
const handleSelect = useCallback((stableId: string) => {
    setState({ mode: "single", channelId, selectedStableId: stableId });
}, [channelId]);

const handleThumbClick = useCallback((e: React.MouseEvent, stableId: string) => {
    e.preventDefault();
    e.stopPropagation();
    isSelectingRef.current = true;
    onSelect(stableId);
    setTimeout(() => { isSelectingRef.current = false; }, 100);
}, [onSelect]);

// ✅ GOOD - Memoized with dependencies
const loadNextChunks = useCallback(async (chunks: number) => {
    // Implementation
}, [channelId, hasMore, pluginSettings.chunkSize, pluginSettings.includeEmbeds, pluginSettings.includeGifs, cache]);
```

### Virtualization for Large Lists

**CRITICAL: Virtualize large lists to prevent performance issues:**

```typescript
// ✅ GOOD - Windowed rendering (only render visible items)
const [visibleRange, setVisibleRange] = useState({ start: 0, end: 50 });
const BUFFER_ROWS = 2; // Render 2 rows outside viewport

const calculateVisibleRange = useCallback(() => {
    const scrollEl = scrollContainerRef.current;
    if (!scrollEl || filteredItems.length === 0) return;

    const { scrollTop, clientHeight } = scrollEl;
    const { columns, cell } = gridLayout;
    const rowHeight = cell + GAP;
    
    const startRow = Math.max(0, Math.floor(scrollTop / rowHeight) - BUFFER_ROWS);
    const visibleRows = Math.ceil(clientHeight / rowHeight);
    const endRow = Math.min(
        startRow + visibleRows + BUFFER_ROWS * 2,
        Math.ceil(filteredItems.length / columns)
    );
    
    const start = Math.max(0, startRow * columns);
    const end = Math.min(filteredItems.length, endRow * columns);
    
    setVisibleRange(prev => {
        // Only update if range changed significantly
        if (Math.abs(prev.start - start) > columns || Math.abs(prev.end - end) > columns) {
            return { start, end };
        }
        return prev;
    });
}, [filteredItems.length, gridLayout]);

// Render only visible items
const itemsToShow = useMemo(() => {
    return filteredItems.slice(visibleRange.start, visibleRange.end);
}, [filteredItems, visibleRange]);

// Use spacers to maintain scroll height
const totalRows = Math.ceil(filteredItems.length / columns);
const totalHeight = totalRows * (cell + GAP) - GAP + PADDING * 2;
const topSpacerHeight = Math.max(0, (Math.floor(visibleRange.start / columns)) * (cell + GAP));
const bottomSpacerHeight = Math.max(0, totalHeight - topSpacerHeight - (Math.ceil((visibleRange.end - visibleRange.start) / columns) * (cell + GAP)));

return (
    <div className="vc-gallery-grid">
        {topSpacerHeight > 0 && (
            <div style={{ height: topSpacerHeight, gridColumn: `1 / -1` }} />
        )}
        {itemsToShow.map(item => <ThumbnailItem key={item.stableId} {...props} />)}
        {bottomSpacerHeight > 0 && (
            <div style={{ height: bottomSpacerHeight, gridColumn: `1 / -1` }} />
        )}
    </div>
);
```

### RequestAnimationFrame for Smooth Updates

**Use requestAnimationFrame for scroll/visual updates:**

```typescript
// ✅ GOOD - RAF for scroll handling
const handleScroll = useCallback(() => {
    if (rafIdRef.current !== null) return;

    rafIdRef.current = requestAnimationFrame(() => {
        rafIdRef.current = null;
        const el = scrollContainerRef.current;
        if (!el) return;
        
        // Update visible range
        calculateVisibleRange();
        
        // Load more when near bottom
        const distanceFromBottom = el.scrollHeight - el.scrollTop - el.clientHeight;
        if (distanceFromBottom < LOAD_MORE_THRESHOLD && !isLoading && hasMore) {
            onLoadMore();
        }
    });
}, [hasMore, isLoading, onLoadMore, calculateVisibleRange]);
```

### Debouncing & Throttling

**Debounce/throttle expensive operations:**

```typescript
import { debounce } from "@utils";

// ✅ GOOD - Debounced updates
const debouncedUpdate = debounce(() => {
    updateFunction();
}, 300);

// ✅ GOOD - Throttled scroll updates
const handleScroll = useCallback(() => {
    if (rafIdRef.current !== null) return; // Throttle via RAF
    rafIdRef.current = requestAnimationFrame(() => {
        rafIdRef.current = null;
        // Update logic
    });
}, []);
```

