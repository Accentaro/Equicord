## API Calls & Fetching

### RestAPI Patterns

**USE RestAPI from @webpack/common:**

```typescript
import { RestAPI, Constants } from "@webpack/common";

// ✅ GOOD - API call with error handling
async function fetchMessagesChunk(args: {
    channelId: string;
    before: string | null;
    limit: number;
    signal?: AbortSignal;
}): Promise<any[]> {
    if (!args.channelId) return [];
    if (args.signal && args.signal.aborted) {
        throw new Error("AbortError");
    }

    try {
        const res = await RestAPI.get({
            url: Constants.Endpoints.MESSAGES(args.channelId),
            query: {
                limit: args.limit,
                ...(args.before ? { before: args.before } : {})
            },
            retries: 1
        });

        if (args.signal && args.signal.aborted) {
            throw new Error("AbortError");
        }

        if (!res) return [];
        const body = res.body ?? res;
        if (!Array.isArray(body)) return [];
        return body;
    } catch (e: unknown) {
        if (args.signal && args.signal.aborted) {
            throw new Error("AbortError");
        }
        if (e instanceof Error && (e.name === "AbortError" || e.message === "AbortError")) {
            throw new Error("AbortError");
        }
        throw new Error("fetch_failed");
    }
}
```

