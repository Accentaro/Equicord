## Error Handling

### Try-Catch Patterns

**ALWAYS wrap async operations and risky code in try-catch:**

```typescript
// ✅ GOOD - Async operations
async function executeCommand(entry: CommandEntry) {
    try {
        await entry.handler();
        recordRecent(entry.id);
    } catch (error) {
        Toasts.show({
            message: `Command failed: ${entry.label}`,
            type: Toasts.Type.FAILURE,
            id: Toasts.genId(),
        });
        console.error("CommandPalette", error);
    }
}

// ✅ GOOD - Risky operations with fallback
async function toggleEnabled(name: string) {
    try {
        const result = wasEnabled ? stopPlugin(plugin) : startPlugin(plugin);
        if (!result) {
            settings.enabled = false;
            showErrorToast(`Error while ${wasEnabled ? "stopping" : "starting"} plugin ${name}`);
            return false;
        }
    } catch (e) {
        new Logger("EquicordHelper").error("Error while toggling:", e);
        showToast(`Failed to ${label.toLowerCase()}`, Toasts.Type.FAILURE);
        return false;
    }
}

// ✅ GOOD - Optional chaining for safe access
if (typeof window !== "undefined" && (window as any).Vencord?.Api?.Themes?.initQuickCssThemeStore) {
    (window as any).Vencord.Api.Themes.initQuickCssThemeStore(m);
}
```

### Error Boundaries

**ALWAYS wrap user-facing components with ErrorBoundary:**

```typescript
import ErrorBoundary from "@components/ErrorBoundary";

// ✅ GOOD - Wrap components
export const PluginButtons = ErrorBoundary.wrap(function PluginCards({ message }: { message: Message; }) {
    // Component code
}, { noop: true }); // noop: true for non-critical components

// ✅ GOOD - In modal rendering
modalKey = openModal(
    ErrorBoundary.wrap(modalProps => (
        <GalleryModal {...modalProps} />
    ), { noop: true }),
    { onCloseCallback: () => { /* ... */ } }
);
```

### Early Validation

**Validate inputs and state early to prevent errors:**

```typescript
// ✅ GOOD - Early validation
function canUseGallery(channel: Channel | null | undefined): boolean {
    if (!channel) return false; // Validate first
    if (!isSupportedChannel(channel)) return false;
    if (channel.guild_id && !PermissionStore.can(PermissionsBits.VIEW_CHANNEL, channel)) return false;
    return true;
}

// ✅ GOOD - Array bounds checking
const lastMsg = msgs[msgs.length - 1];
if (lastMsg && lastMsg.id) {
    before = String(lastMsg.id);
} else {
    localHasMore = false;
    break;
}
```

