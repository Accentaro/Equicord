## Component Patterns

### Conditional Rendering

**Early returns for invalid states:**

```typescript
// ✅ GOOD - Early validation and return
export function SingleView(props: Props) {
    const selectedIndex = useMemo(() => {
        if (!items || items.length === 0 || !selectedStableId) return -1;
        return items.findIndex(item => item && item.stableId === selectedStableId);
    }, [items, selectedStableId]);

    // Auto-advance to next valid if current is invalid
    useEffect(() => {
        if (selectedIndex < 0 || selectedIndex >= items.length) {
            const nextValid = items.find(item => item && item.stableId && !cache.failedIds.has(item.stableId));
            if (nextValid) {
                onChange(nextValid.stableId);
            } else {
                onClose();
            }
            return;
        }
    }, [selectedIndex, items, cache.failedIds, onChange, onClose]);

    if (selectedIndex < 0 || selectedIndex >= items.length) return null;
    const item = items[selectedIndex];
    if (!item || !item.url || cache.failedIds.has(item.stableId)) return null;

    // Render component
}
```

### Loading States

**Pattern for loading/error states:**

```typescript
// ✅ GOOD - Loading and error handling
const [loading, setLoading] = useState<boolean>(false);
const [error, setError] = useState<string | null>(null);

const loadData = useCallback(async () => {
    if (loadingRef.current) return;
    loadingRef.current = true;
    setLoading(true);
    setError(null);

    const controller = new AbortController();
    abortRef.current?.abort();
    abortRef.current = controller;

    try {
        const data = await fetchData({ signal: controller.signal });
        setItems(data);
    } catch (e: unknown) {
        if (e instanceof Error && (e.name === "AbortError" || e.message === "AbortError")) {
            return; // Aborted, don't show error
        }
        setError("Unable to load data");
    } finally {
        loadingRef.current = false;
        setLoading(false);
    }
}, []);
```

### AbortController for Cancellation

**Use AbortController for async operations:**

```typescript
// ✅ GOOD - AbortController pattern
const abortRef = useRef<AbortController | null>(null);

const loadData = async () => {
    const controller = new AbortController();
    abortRef.current?.abort(); // Cancel previous
    abortRef.current = controller;

    try {
        const data = await fetchData({ signal: controller.signal });
        // Check if aborted
        if (controller.signal.aborted) {
            const err = new Error("AbortError");
            err.name = "AbortError";
            throw err;
        }
        setItems(data);
    } catch (e) {
        if (e instanceof Error && e.name === "AbortError") {
            return; // Aborted, ignore
        }
        setError("Failed to load");
    }
};

// Cleanup
useEffect(() => {
    return () => abortRef.current?.abort();
}, []);
```

