## Settings Management

### definePluginSettings

**Pattern for plugin settings:**

```typescript
import { definePluginSettings } from "@api/Settings";
import definePlugin, { OptionType } from "@utils/types";

const settings = definePluginSettings({
    enabled: {
        type: OptionType.BOOLEAN,
        description: "Enable feature",
        default: true,
    },
    chunkSize: {
        type: OptionType.NUMBER,
        default: 100,
        description: "Messages per chunk (25–100)",
        isValid: v => {
            const num = typeof v === "string" ? Number(v) : v;
            return Number.isFinite(num) && num >= 25 && num <= 100;
        },
    },
    buddy: {
        type: OptionType.SELECT,
        description: "Pick a cursor buddy",
        options: [
            { label: "Oneko", value: "oneko", default: true },
            { label: "Fatass Horse", value: "fathorse" }
        ],
        onChange: load, // Callback when setting changes
    },
}, {
    // Setting checks (conditional disabling)
    fps: {
        disabled() { return this.store.buddy !== "fathorse"; }
    }
});

export default definePlugin({
    settings,
    start() {
        // Access settings
        const value = settings.store.enabled;
        
        // Update settings (auto-saves)
        settings.store.enabled = false;
    }
});

// In React component
function MyComponent() {
    const { enabled, chunkSize } = settings.use(["enabled", "chunkSize"]);
    // Or use all
    const allSettings = settings.use();
}
```

